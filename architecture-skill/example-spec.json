   { "s": "proc",   "d": "a",    "kind": "req", "label": "2a write",     "n": "2a", "ss": "tr", "ds": "l",  "via": [[660, 150]] },
   { "s": "proc",   "d": "c",    "kind": "req", "label": "2c write",     "n": "2c", "ss": "br", "ds": "l",  "via": [[660, 510]] },

   { "s": "b",      "d": "dash", "kind": "sup", "label": "rollup",       "n": "3",  "ss": "r",  "ds": "l",  "via": null },
