   { "key": "a",      "x": 950,  "y": 150, "icon": "db",         "title": "Store A",   "sub": "/facts",         "label": "below" },
   { "key": "b",      "x": 950,  "y": 330, "icon": "db",         "title": "Store B",   "sub": "/prefs",         "label": "below" },
   { "key": "c",      "x": 950,  "y": 510, "icon": "db",         "title": "Store C",   "sub": "/summaries",     "label": "below" },
   { "key": "dash",   "x": 1180, "y": 330, "icon": "cloudwatch", "title": "Rollup",    "sub": "dashboard",      "label": "below" }
  ],
  "groups": [
